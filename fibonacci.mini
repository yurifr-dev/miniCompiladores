// =============================================
// Programa de exemplo: Fibonacci iterativo
// Linguagem: Mini
// =============================================

// Calcula o n-ésimo número de Fibonacci
int n = 10;
int a = 0;
int b = 1;
int i = 0;

while (i < n) {
    int temp = a + b;
    a = b;
    b = temp;
    i = i + 1;
}

print(a);
